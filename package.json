{
    "name": "filament-quill",
    "private": "true",
    "type": "module",
    "scripts": {
        "dev:scripts": "node bin/build.js --dev",
        "dev:styles": "tailwindcss -i resources/css/app.css -o resources/dist/filament-quill.css --postcss --watch",
        "build:scripts": "node bin/build.js",
        "build:styles": "tailwindcss -i resources/css/app.css -o resources/dist/filament-quill.css --postcss --minify",
        "dev": "npm-run-all --parallel dev:*",
        "build": "npm-run-all build:*"
    },
    "dependencies": {
        "@enzedonline/quill-blot-formatter2": "^3.2.0",
        "@tailwindcss/cli": "^4.3.1",
        "@tailwindcss/postcss": "^4.3.1",
        "@tailwindcss/typography": "^0.5.20",
        "quill": "2.0.2",
        "tailwindcss": "^4.3.1"
    },
    "devDependencies": {
        "autoprefixer": "^10.5.2",
        "esbuild": "^0.28.1",
        "npm-run-all": "^4.1.5",
        "postcss": "^8.5.16",
        "postcss-import": "^16.1.1"
    }
}
